// Copy this file to `secrets.h` (which is git-ignored) and set your own passkey.
//
//   cp src/secrets.h.example src/secrets.h
//
// The passkey is the 6-digit number the BLE central enters once, during pairing,
// to get an authenticated (MITM-resistant) bond. After pairing it's never used
// again — the bond keys take over. Pick any 6-digit value (000000–999999).
//
// If you switch the firmware to "Just Works" pairing (no MITM, see main.cpp),
// this value is ignored but the symbol still needs to exist for the build.

#pragma once

#define BLE_PASSKEY 123456
